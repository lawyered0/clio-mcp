# Clio OAuth credentials. Get these from Clio's Developer Applications page:
#   https://app.clio.com/settings/developer_applications  (US)
#   https://ca.app.clio.com/settings/developer_applications  (CA)
#   etc.
# See docs/oauth-setup.md for the first-time authorization-code dance that
# turns CLIENT_ID + CLIENT_SECRET into a refresh token.
CLIO_CLIENT_ID=<your_client_id>
CLIO_CLIENT_SECRET=<your_client_secret>
CLIO_REFRESH_TOKEN=<your_refresh_token>

# Optional: Region endpoints. Defaults to US (app.clio.com).
# IMPORTANT: don't mix regions — token from one region won't auth at another (401).
#   US:    https://app.clio.com/...
#   CA:    https://ca.app.clio.com/...
#   EU/UK: https://eu.app.clio.com/...
#   AU:    https://au.app.clio.com/...
# CLIO_BASE_URL=https://app.clio.com/api/v4/
# CLIO_TOKEN_URL=https://app.clio.com/oauth/token

# Optional: default responsible_attorney + originating_attorney for clio_create_matter.
# If unset, the tool requires attorney_id as an explicit parameter.
# Find your user id with clio_who_am_i.
# CLIO_DEFAULT_ATTORNEY_ID=

# Optional: HTTP server bind config (only used when running without --stdio).
# CLIO_MCP_HOST=127.0.0.1
# CLIO_MCP_PORT=8765
